[{"id":"845dfd7dab1777","city":"西宁","region":"青海","district":"区域待补充","category":"烧烤 / 烤肉","name":"青海名吃尕张娃烤肉(海湖总店)","address":"青海名吃尕张娃烤肉(海湖总店) 青海省西宁市城西区西川南路彭家寨村小区新村综合办公楼一楼","tips":"早预定，会排队，本地人吃的，家庭聚餐也可，有大包厢","note":"手抓，炕洋芋好吃必点；小童去了塔尔寺、藏文化博物馆和安多手工店（我的眼睛包好使的）；塔尔寺属于藏传佛教区建议不要穿太短的裙子或者是短裤；景区门口有拍写真照片可以货比三家，砍砍价","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":4},{"id":"36ad902648fb0d","city":"西宁","region":"青海","district":"区域待补充","category":"其他美食","name":"尕晋娃抓面","address":"连锁店","tips":"本地人吃的，羊头肉是gengjiugengjiu的，","note":"可以点一份素面，另点一份你想吃的肉类，花面是各种肉类一样来一点","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":5},{"id":"7517e7c3277644","city":"西宁","region":"青海","district":"区域待补充","category":"早餐 / 小吃","name":"郭老大臭豆腐","address":"西宁市东交通巷6号","tips":"老板很随性，看心情上班","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":6},{"id":"24af132ba5ceea","city":"西宁","region":"青海","district":"区域待补充","category":"火锅 / 串串","name":"张氏姊妹麻辣烫","address":"连锁店","tips":"自己拿串","note":"别的地方没有的麻辣烫味道（辣椒是灵魂，韭叶粉也好吃）","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":7},{"id":"e9d9145bd76769","city":"西宁","region":"青海","district":"区域待补充","category":"其他美食","name":"胡菲烤面筋","address":"连锁店","tips":"真的超好吃，但晚上高峰期排队比较久，可以点好先去逛别的","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":8},{"id":"165875cead3e75","city":"西宁","region":"青海","district":"区域待补充","category":"甜品 / 饮品","name":"宝葫芦西北茶食铺","address":"连锁店","tips":"奶茶大杯真的很大","note":"经典甜醅奶茶推荐，麻辣流汁洋芋片；面筋也好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":9},{"id":"2c3535cef14bc0","city":"西宁","region":"青海","district":"区域待补充","category":"火锅 / 串串","name":"华殷麻辣烫","address":"海湖新区","tips":"芝麻很多 很香 老牌子了","note":"每个菜都好吃；每年回家13个小时的高铁就靠这一口麻辣烫撑着！","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":10},{"id":"00c8c28c2575a8","city":"西宁","region":"青海","district":"区域待补充","category":"火锅 / 串串","categoryDetail":"肉肉肉","name":"羊肉扎锅","address":"地址待核验","tips":"超级无敌好吃","note":"火锅、羊头、牛排","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":11},{"id":"a7fdce6ec66634","city":"西宁","region":"青海","district":"区域待补充","category":"甜品 / 饮品","categoryDetail":"奶茶","name":"放哈奶茶店","address":"连锁店","tips":"出餐有点慢","note":"经典甜醅子奶茶很好喝，茶底是茉莉花味的","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":12},{"id":"bc89048226e75b","city":"西宁","region":"青海","district":"区域待补充","category":"面食 / 米粉","categoryDetail":"米线","name":"川名佬总店","address":"城西区学院巷一个犄角旮旯的米线","tips":"尊嘟炒鸡好吃每次放假回家都要吃什么实力","note":"各种口味米线","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":13},{"id":"e38f1177f21bfd","city":"西宁","region":"青海","district":"区域待补充","category":"米饭 / 简餐","categoryDetail":"西餐","name":"福炉三麦精酿啤酒餐厅","address":"力盟步行街/新华联广场","price":"略贵，两个人三百，但是很撑","tips":"饭点可能会排队","note":"水果披萨强推！我愿称之为吃过的最好吃的披萨","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":14},{"id":"c443f013323934","city":"西宁","region":"青海","district":"区域待补充","category":"其他美食","categoryDetail":"面食","name":"伊彩兴抓面","address":"同仁路","price":"13/大 12/小碗","tips":"可以几种拼在一起","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":15},{"id":"d19b8645082e43","city":"西宁","region":"青海","district":"区域待补充","category":"其他美食","categoryDetail":"牦牛大骨汤","name":"鲁老大牦牛大骨汤","address":"城北区西海路51号西格城市广场A-17号","price":"小碗22 团购15","tips":"中午人多可以早一点去","note":"我吃了中碗的，超好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":17},{"id":"e649a04349820b","city":"西宁","region":"青海","district":"区域待补充","category":"地方菜","categoryDetail":"纸包鱼","name":"重庆纸包鱼川菜馆","address":"城东区德令哈路","price":"人均三四十（人多一点的话）人多一点去吃会好一点，可以团购，也可以单点","note":"我们一般都是吃梭边鱼，没刺","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":18},{"id":"8cf3cb9fa57064","city":"西宁","region":"青海","district":"区域待补充","category":"火锅 / 串串","categoryDetail":"火锅","name":"芳姐小火锅","address":"兴海路","price":"人均70左右","tips":"店面很小 很容易错过","note":"麻辣牛肉片 就吃吧 一吃一个不吱声","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":19},{"id":"cb97abd62b6ecf","city":"西宁","region":"青海","district":"区域待补充","category":"面食 / 米粉","categoryDetail":"炕锅羊肉","name":"清真·舒迩布炕锅王·高原美食文化（青海总店）","address":"城东区湟中路青藏铁路花园西门口（中国工商银行隔壁）","price":"有套餐，双人的97","tips":"人多，有可能会需要等位","note":"炕锅羊肉好吃！面皮超好吃！酸奶一般","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":20},{"id":"82dd2367d2b653","city":"西宁","region":"青海","district":"区域待补充","category":"面食 / 米粉","categoryDetail":"大盘鸡","name":"胡才撒尔塔大盘鸡餐厅","address":"地址待核验","price":"忘了","tips":"没啥注意事项","note":"吃了大盘鸡双人套餐，好吃！里面面皮超好吃！老板人也很好送了我们两盒酸奶，他家酸奶比上面那家好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":21},{"id":"47218a9ce69dbb","city":"西宁","region":"青海","district":"区域待补充","category":"面食 / 米粉","categoryDetail":"手抓羊肉","name":"益鑫手抓羊肉","address":"地址待核验","tips":"清真，不得带外来食物","note":"老牌子了，他家的馍馍也很好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":22},{"id":"de0ada93322a61","city":"西宁","region":"青海","district":"区域待补充","category":"烧烤 / 烤肉","categoryDetail":"炕锅羊肉，羊肉串","name":"马相卿烤肉美食店","address":"盐湖巷","price":"羊肉是98一斤平常，羊肉串3元一串","tips":"节假日排队，下午五点左右开门","note":"超级爱炕锅羊肉，不过他们家大棒骨慎重选择，大部分都是骨头，而且没有什么肉；马相卿特色烤肉面食馆（虎台店） 小羊排真的超级香 这个有两家店 小红书推荐的都是这家 份量挺大的 适合三个人及以上去吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":25},{"id":"690128a5901498","city":"西宁","region":"青海","district":"湟源县","category":"其他美食","categoryDetail":"酸辣里脊","name":"魁盛酒楼","address":"北大路","price":"小份68大份98","note":"现浇的汁，外酥里嫩；我建议明清老街城门右侧那家，那家也好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":26},{"id":"2891cf5d4d7d72","city":"西宁","region":"青海","district":"湟源县","category":"其他美食","categoryDetail":"甜醅","name":"魏家奶奶","address":"明清老街，城关第一小学对面","price":"一碗5元","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":27},{"id":"e11e49b531961e","city":"西宁","region":"青海","district":"湟源县","category":"其他美食","categoryDetail":"柴火鸡","name":"乡村散养柴火鸡","address":"北极山脚下","price":"有套餐","tips":"土鸡，肌肉不柴不腥","note":"秘制酱料好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":28},{"id":"afd87434ef0868","city":"西宁","region":"青海","district":"城西区","category":"其他美食","categoryDetail":"面食","name":"青山酿皮","address":"同仁路送变电楼下","price":"20左右","tips":"人多，要自己拿面","note":"一定要吃羊肠！！！！！！！！！！！香翻过","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":29},{"id":"f6f063aafe9e42","city":"西宁","region":"青海","district":"城西区","category":"其他美食","categoryDetail":"小炒","name":"夏都芙蓉小炒","address":"交通医院对面","price":"人均40","tips":"人多，有可能会需要等位","note":"辣子鸡！！！家常土豆片！！超级推荐！！！","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":31},{"id":"e6a37e948d77e6","city":"西宁","region":"青海","district":"城中区","category":"汤锅 / 炖菜","categoryDetail":"砂锅","name":"新禾砂锅","address":"大兴街夜市内","price":"我人均30-40","tips":"附近不好停车，可以停到文庙内","note":"手擀粉炒牛柳，土豆片，都好吃，也有砂锅，可以免费续汤","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":32},{"id":"961101c0737e2a","city":"果洛州","region":"青海","district":"玛沁县","category":"火锅 / 串串","categoryDetail":"串串","name":"火辣串串香","address":"甘德路与团结路交叉口东北160米（一校旁）","price":"人均50","tips":"人少不用排队","note":"青椒牛肉值得一吃！味道都很不错","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":33},{"id":"9740d0ffaeace5","city":"西宁","region":"青海","district":"西宁市","category":"甜品 / 饮品","categoryDetail":"奶茶","name":"宝葫芦西北茶食铺","address":"西宁万达，唐道，力盟步行街等等商场","price":"奶茶15左右不等，小食也是","tips":"人可能比较多","note":"都好吃，特色是甜醅子奶茶，好喝，大桶奶茶力推","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":34},{"id":"fd8c0f395f0c62","city":"西宁","region":"青海","district":"西宁市","category":"火锅 / 串串","name":"酷爷麻辣烫","address":"海湖新区 万达金街","price":"人均20 30","tips":"注意点微微辣。微辣太辣了 麻辣烫反而没有那么好吃，不用要料碗","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":35},{"id":"afa0f71365c029","city":"西宁","region":"青海","district":"城西区","category":"面食 / 米粉","categoryDetail":"米粉","name":"天全唐王米粉","address":"兴海路23号","price":"人均20左右","tips":"店面有点小，饭点人多，有红汤和清汤的","note":"细粉，牛肉米粉好吃，稍微有点辣，非常四川的味道","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":36},{"id":"765c55ee0f4263","city":"西宁","region":"青海","district":"湟源县","category":"其他美食","categoryDetail":"十大碗","name":"魁盛酒楼","address":"湟源县北大路","price":"人均八九十","tips":"类似于一桌席，都是湟源特色菜，最好多人去，三四个人可能吃不完","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":37},{"id":"b239948768d27f","city":"西宁","region":"青海","district":"城西区","category":"烧烤 / 烤肉","categoryDetail":"炕锅羊肉","name":"清真烧烤·伊福德炕肉·西北菜（省博物馆 店）","address":"城西区交通巷15号","price":"人均70左右","tips":"一楼是小门面，二楼有桌子吃饭，可能不是很好找","note":"美团点的那个套餐有炕锅，酿皮和萝卜丝，炕锅给我一种这辈子值了的感觉，酿皮也很好吃，辣椒很香，萝卜丝应该是现切的，辣辣的有点；好吃！炕锅小份两个人吃足够了，杏皮茶好喝","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":39},{"id":"d13b68738bbfd6","city":"西宁","region":"青海","district":"城西区","category":"其他美食","categoryDetail":"炮仗面","name":"金一碗生炒炮仗","address":"城西区兴海路小学西南门旁","price":"人均20-50","tips":"美食博主唐人杰（探店齁币多，真假厨子说）光顾过并且好评","note":"吃了生炒炮仗和收银台旁边的肉，都很好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":40},{"id":"c6bd8e78fbb0db","city":"西宁","region":"青海","district":"城西区","category":"早餐 / 小吃","categoryDetail":"臭豆腐","name":"长沙臭豆腐","address":"城西区商业巷南口旁边的小巷子口","price":"好像是一份12 有点忘了","tips":"可能会有点辣，可以要少辣，可能会遇到人多排队的情况","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":42},{"id":"1aae6aca36f327","city":"西宁","region":"青海","district":"城西区","category":"烧烤 / 烤肉","categoryDetail":"马有鱼和唐炫宫烤肉","name":"马有鱼馕坑烤鱼","address":"分店特别多地图都能搜到","price":"人均50","tips":"麻辣和酸菜好吃，酸汤一般","note":"很入味，还可以点小酥肉","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":43},{"id":"8e1471753e485a","city":"西宁","region":"青海","district":"城西区","category":"其他美食","name":"祁记面片","address":"唐道那边","price":"人均40左右","tips":"好吃，酸汤也好喝得很","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":44},{"id":"366080a7b90eb1","city":"西宁","region":"青海","district":"湟源县","category":"面食 / 米粉","categoryDetail":"米线","name":"云南过桥米线","address":"体育场对面步行街","price":"人均20-30","tips":"点超辣（不能吃辣的慎点）大饼 汤汁很香","note":"粉是土豆粉 很香","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":45},{"id":"67c012b01011fc","city":"西宁","region":"青海","district":"城北区","category":"火锅 / 串串","categoryDetail":"火锅鸡","name":"咕咕火火锅鸡","address":"城北国际村","price":"人均70","tips":"点中辣，鸡肉入味，免费涮菜，还有冰淇淋奥","note":"点了全家福，不错","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":46},{"id":"345b4558f3e6ee","city":"西宁","region":"青海","district":"城西","category":"火锅 / 串串","categoryDetail":"羊蝎子火锅","name":"巴特羊蝎子火锅","address":"虎台","price":"人均80","tips":"可以要个全家福，你就吃吧，羊肉没有膻味","note":"可以根据自己调料，外地的宝宝真的推荐去尝尝","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":47},{"id":"1fa58ef4e9f045","city":"西宁","region":"青海","district":"城中区","category":"面食 / 米粉","categoryDetail":"羊肉汤","name":"齐记重阳羊肉汤","address":"莫家街头头往里","price":"人均20","tips":"超级好吃，里面的馍馍加了特制的辣子绝绝子","note":"不能吃辣的宝贝要少放一点，先尝尝怎么样，然后酌情加；羊肉汤小碗就很多了，大碗男生都吃不完。料很多羊肉粉丝木耳萝卜，馍夹辣子也好吃泡羊肉汤里也好吃！感谢推荐！好吃！","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":48},{"id":"cf5965a170051b","city":"西宁","region":"青海","district":"城中区","category":"烧烤 / 烤肉","categoryDetail":"烤肉","name":"马相亲烤肉","address":"地址待核验","price":"人均70左右","tips":"里面的骨髓很绝","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":49},{"id":"f23264567b6e70","city":"西宁","region":"青海","district":"城西区","category":"其他美食","categoryDetail":"关东煮🍢","name":"乔客叔叔关东煮","address":"商业巷里面","price":"价格合适","tips":"清真小店面","note":"清汤可以喝 可以吃辣的可以点中辣🥵","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":50},{"id":"bc51e9ff8a4cdb","city":"西宁","region":"青海","district":"城西区","category":"其他美食","categoryDetail":"羊杂碎","name":"晓泉鲜香杂碎店","address":"地址待核验","price":"人均20","tips":"人很多，要早点去","note":"味道很不错，就是量没有以前多了","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":51},{"id":"21330ab2d4952b","city":"西宁","region":"青海","district":"城中区","category":"早餐 / 小吃","categoryDetail":"油炸糕","name":"何家油炸糕","address":"水井巷（正对水井巷北门左边那条路进去200米左右）","price":"一个2元","tips":"清真店！百年老字号 非常火爆 每次去都要排队 如果下午去就已经卖完了 里面是五仁馅 甜口","note":"这个真的很好吃 从小吃到大 每次想去吃都排不到！","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":52},{"id":"5f5c178d44d9b9","city":"西宁","region":"青海","district":"城东区","category":"其他美食","categoryDetail":"柴火鸡","name":"玉峰阁柴火鸡（四分店）","address":"五三六医院公交站318号","price":"人均50多","tips":"清真店 味道不错 可电话预定包间 适合人多去","note":"一定要花卷 沾汤吃超级香 炕锅鱼味道也不错","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":54},{"id":"79e10115610da8","city":"西宁","region":"青海","district":"湟源县","category":"面食 / 米粉","categoryDetail":"羊杂（里面有羊肚，羊头皮，头肉啥的，纯肉还有汤，香麻了老师们）","name":"原汁原味杂碎铺","address":"林业局家属院对面（或者供电局斜对面）认准红色招牌红色防盗门挂红灯笼这家，这家最正宗😋","price":"大碗25（全肉+一个大饼）30优质（会加肉但是我感觉有点多）","tips":"超极正宗的本地羊杂，汤是白汤，拿羊脑熬出来的，25一大碗全是肉！还送一个大饼，很大一个超级顶饱，算是当地比较特色的。但是个人观感和螺蛳粉有点像，会有味道。就是那家店据说开了四五十年，店里羊肉味比较重，当时我和朋友一起去的，我朋友就有点不习惯，但是我没咋闻出来，肚丝和头皮肉都很干净。我和朋友去的时候十二点左右，老板是个很热情的阿姨，所以一直记到了现在🥺","note":"建议早点去吃，下午就关门了。吃之前先垫两口大饼，空腹直接吃肉感觉会不舒服😥；大概长这样，加很多辣椒就馍吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":55},{"id":"5e64c1273215cb","city":"西宁","region":"青海","district":"城东区、城西区","category":"火锅 / 串串","categoryDetail":"火锅","name":"清真·东串串火锅","address":"城东店：1、共和南路（新千店）2、大众街（总店） 城西区 ：力盟商业巷（力盟店） 高德都可以搜到","price":"人均80","tips":"清真店 吃完整个人会被腌入味 很多天都散不了 建议穿脏衣服去哈哈哈哈哈哈 排队人很多任何一个店 提前在手机上美食不用等排队再过去","note":"真的超级超级超级好吃 自封西宁串串火锅No.1 锅底挺辣的 料碗里的酱也很辣 不能吃辣的禾慎入 牛肥肠一定一定必吃好吃到爆","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":56},{"id":"d4a3d10bd6c76c","city":"西宁","region":"青海","district":"城中区","category":"甜品 / 饮品","categoryDetail":"酸奶","name":"伊味滋自制酸奶","address":"香格里拉砖场路","price":"一碗3块","tips":"不能堂食","note":"我觉得是最本地的酸奶，一定要点有糖的，上面有一层黄色的奶皮好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":59},{"id":"18d0b916338a6f","city":"西宁","region":"青海","district":"城东区","category":"烧烤 / 烤肉","categoryDetail":"酸辣粉","name":"糊涂香","address":"东稍门车站背后的那家","price":"人均20+","tips":"清真店 一定只有这家的才好吃才正宗 从初中就开始吃 现在都上班两年了还在吃 其他搜出来的糊涂香都是后面开的 自我感觉是冒牌哈哈哈哈哈哈","note":"里面的随便一种都特别好吃 最最推荐鸡丝酸辣粉 干拌空心粉 烧烤菜（很正宗的老式烧烤味）其他也好吃 就没有不好吃的他家！！！","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":60},{"id":"1a36f8c3ebe3c3","city":"西宁","region":"青海","district":"全西宁可配送 也可自取","category":"日韩料理","categoryDetail":"寿司","name":"小程序下单（码放后面图片咯）","address":"私房寿司 只在微信上接单","price":"100左右","tips":"清真店 要早点预定 每日有限量 里面的口味可以适当换 要微信给店主提前说 量很大 一个寿司有半个手掌那么大 人多再点 不然吃不完就浪费了 一个人可以点小小盒","note":"yummy！！里面的米特别新鲜软糯","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":63},{"id":"72c0ac65f56a9a","city":"西宁","region":"青海","district":"湟源县","category":"其他美食","categoryDetail":"酿皮","name":"买娃酿皮（清真）","address":"湟源县人民医院旁市场里面","price":"一碗7块","tips":"清真店，早上要早点买，下午去就没有了","note":"好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":64},{"id":"3b01d3cddec76d","city":"西宁","region":"青海","district":"城北区","category":"汤锅 / 炖菜","categoryDetail":"砂锅刀削面","name":"杨爱雨砂锅刀削面","address":"连锁店","price":"小份13 大份16","tips":"可以点两掺 是刀削面和土豆粉","note":"口味很多 有微辣 麻辣 酸辣 砂锅里面还有其他配菜 里面的丸子真的巨好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":65},{"id":"cf9e0173c25b83","city":"西宁","region":"青海","district":"城北区","category":"早餐 / 小吃","categoryDetail":"臭豆腐","name":"臭名远扬臭豆腐","address":"小桥市场直走最里面","price":"小份10元 大份15元","note":"这里得臭豆腐真的巨好吃 酱料和别人的不一样！","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":66},{"id":"fbb84a9077f9f5","city":"西宁","region":"青海","district":"城北区","category":"火锅 / 串串","categoryDetail":"麻辣烫","name":"马丽娜麻辣烫","address":"小桥市场里面","price":"人均20+","tips":"饭点人可能会多一点","note":"店里的吃的都不会踩雷，想尝特色的可以点酿皮、梗皮。一定要吃麻辣烫 ，辣子不会很辣，这里的辣子是香的","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":67},{"id":"9f66b14f40cb3c","city":"西宁","region":"青海","district":"城北区","category":"其他美食","categoryDetail":"麻糍 糯叽叽 打糕 松糕","name":"米糕小栈","address":"小桥市场直走最里面 在臭名远扬臭豆腐对面","price":"价格都是十几块","tips":"在美团上可以搜到 去之前搜一下有没有开店 如果卖完了会提前关店","note":"巨巨巨巨巨好吃 每次去都会买 我爱吃茉莉青提 杨枝甘露的也很好吃 他们家的麻糍外皮是自己手工制作的 吃起来不会粘牙 非常的有嚼劲 用料很足","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":68},{"id":"49ad4b5088b851","city":"西宁","region":"青海","district":"城东区","category":"烧烤 / 烤肉","categoryDetail":"烧烤","name":"串搭子","address":"宝宝们直接搜名字找地方 我忘记了……","price":"80左右","tips":"清真","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":69},{"id":"81a2a42262d67e","city":"德令哈","region":"青海","district":"湟源县","category":"烧烤 / 烤肉","name":"佳味海鲜","address":"体育场附近","tips":"推荐海鲜拼盘 十年老店","note":"烧烤 单独的炒海鲜都好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":72},{"id":"e4fc7d034b19a4","city":"海北州","region":"青海","district":"门源县","category":"火锅 / 串串","categoryDetail":"酿皮麻辣粉","name":"栋栋麻辣烫","address":"大市场正门进去右走之后往前左边店面","price":"特别便宜造就完了","tips":"清真饭馆，从小时候吃到大","note":"酿皮，酸奶都好吃！茶水需要自己倒","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":73},{"id":"68943184bc0679","city":"全省/多地","region":"青海","district":"门源县","category":"其他美食","categoryDetail":"牛肉面","name":"牛多多牛肉面","address":"舒裕华府","tips":"牛肉面里有香菜和葱，不喜欢的提前说","note":"红烧牛肉面肉特别多没有膻味，而且汤特别浓郁特别好喝茶叶蛋也好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":74},{"id":"f472d8efcfaae7","city":"贵德县","region":"青海","district":"门源县","category":"火锅 / 串串","categoryDetail":"干锅","name":"君念美食火锅","address":"迎宾东路二号桥头","price":"两个人一百多","tips":"两斤起拼 随便哪一个都好吃","note":"这好吃的爆炸主推鸡翅虾羊排啥的真的好吃啊最不希望关的店啊我跟朋友每次聚餐指定美食哈哈哈哈哈哈","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":75},{"id":"edaf63136f05f7","city":"格尔木","region":"青海","district":"门源县","category":"烧烤 / 烤肉","categoryDetail":"烧烤、炕锅、面食等","name":"老字号马古白烤羊肉","address":"黄河路街道站前二路51号","price":"人均70左右，但肉串很大，在当地很实惠","tips":"可以少量多种类，份量很足","note":"强力推荐羊肉串、炕锅。麦仁必点，是青海老特色，只有他家口味保持的较为正宗。羊肉串可以把肉拿下来放到麦仁里面，不一样的口感","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":77},{"id":"343a3a01240419","city":"大柴旦","region":"青海","district":"门源县","category":"火锅 / 串串","categoryDetail":"牦牛火锅","name":"不将就石锅特色牦牛体验馆","address":"地址待核验","price":"小贵","tips":"避雷他家，千万别去真的！我们四个人第二天全拉肚子了","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":78},{"id":"6e9117435ec433","city":"格尔木","region":"青海","district":"门源县","category":"汤锅 / 炖菜","categoryDetail":"砂锅","name":"肖婆婆砂锅","address":"地址待核验","price":"套餐48两人","tips":"人贼多可能需要等位","note":"可以点套餐，我印象比较深的是肉末粉丝，很下饭，水煮肉片也可","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":79},{"id":"6ffcabf66e7cfd","city":"茶卡","region":"青海","district":"门源县","category":"火锅 / 串串","categoryDetail":"土火锅","name":"丝路新娘西域美食炕锅土火锅","address":"青海省海西蒙古族藏族自治州乌兰县茶卡镇交通街丝绸之路驿站2-4号商铺回头客超市隔壁","price":"93两人","tips":"店里装修很朴素","note":"手把羊肉很香，酿皮子好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":80},{"id":"37182beaff0bec","city":"海北州","region":"青海","district":"门源县","category":"火锅 / 串串","categoryDetail":"麻辣烫","name":"老字号兰州麻辣烫（旭红风情街店）","address":"旭红购物广场背面","price":"人均20多","tips":"清真店，店主人很好","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":82},{"id":"1305ae784a23ad","city":"玉树自治州","region":"青海","district":"囊谦县","category":"卤味 / 熟食","categoryDetail":"卤菜","name":"禾香缘","address":"正片跳舞那个广场下面50米，左手边，在华信购物旁边","price":"川氏卤菜，价格实惠","tips":"家禾父母开的店，味道超棒哦","note":"每天现卤，基本都卖光了，鸭头，鸡翅，鸭翅，卤鸭都特别哇噻；藏医学校校长给十勤带的卤菜同款哦；哥几个吃了禾爸妈做的卤菜！?","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":83},{"id":"162fecfa84d37d","city":"海东","region":"青海","district":"乐都区","category":"面食 / 米粉","categoryDetail":"炮仗","name":"建忠炒面片","address":"三角花园下面一点","price":"15左右","note":"非常好吃，放辣椒非常好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":84},{"id":"673126ee3441dd","city":"海东","region":"青海","district":"互助县","category":"火锅 / 串串","categoryDetail":"麻辣烫","name":"巧媳妇","address":"富民街巧媳妇","price":"三人吃五十左右","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":85},{"id":"1fe02193d475d4","city":"海东","region":"青海","district":"乐都区","category":"火锅 / 串串","categoryDetail":"火锅","name":"皇三爷火锅","address":"乐都区中心广场对面","price":"反正不贵","note":"番茄锅番茄汤超级好喝","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":88},{"id":"d6607c8aa690e2","city":"海东","region":"青海","district":"互助县","category":"面食 / 米粉","categoryDetail":"新疆炒米粉","name":"疆粉儿新疆炒米粉","address":"海州国际广场","price":"20左右","note":"每次回家必吃，去不了电了也得点外卖，酱香味的巨巨巨好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":89},{"id":"72573382940462","city":"海东","region":"青海","district":"化隆县","category":"火锅 / 串串","categoryDetail":"辣炒年糕鸡爪","name":"碧水庄园","address":"群科新区团一村马家大院隔壁","price":"农家院 和家人朋友一起去更实惠","tips":"清真不能带外来食物","note":"还有重庆火锅，爱吃辣的的禾伙人有福了，鸡爪软烂脱骨，越吃越辣，真的不错！！！十颗⭐推荐","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":90},{"id":"a063dc551da321","city":"海东","region":"青海","district":"互助县","category":"面食 / 米粉","categoryDetail":"过桥米线","name":"川铭佬米线","address":"威远镇东大街","price":"人均20","tips":"店面有点小，饭点人有点多，可能要等待","note":"都很好吃，米线汤泡饭超级好吃！","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":93},{"id":"627f0afb65588c","city":"海东","region":"青海","district":"平安区","category":"面食 / 米粉","categoryDetail":"柴火鸡","name":"大团结柴火鸡","address":"石家营路高铁新区小区A3","price":"人均50＋适合多人","tips":"鸡肉是给你现现炒的，正宗的柴火鸡，本地人也很爱过去吃","note":"口味现场炒制的时候，提前告知，厨师会给你调整，花卷必点，泡着很好吃，也可以拉面在里面煮","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":94},{"id":"425cfaffc8359d","city":"海北州","region":"青海","district":"祁连县","category":"面食 / 米粉","categoryDetail":"炕锅羊肉 炒面片","name":"撒拉尔美食","address":"广场对面的大十字往上走","price":"人均70","tips":"旅游旺季人挺多的 需要早点去","note":"炕锅羊肉 每次去必点，羊肉是按斤称的 炒面片也好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":95},{"id":"dd64142adfdb84","city":"海北州","region":"青海","district":"祁连县","category":"汤锅 / 炖菜","categoryDetail":"牛肉砂锅","name":"西海砂锅","address":"图书馆旁边","price":"13一份","tips":"店面较小 饭点人很多","note":"本地人很喜欢吃 不知道符不符合其他姐妹的口味 可以去尝尝","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":96},{"id":"8791b802bcd374","city":"大柴旦","region":"青海","district":"祁连县","category":"汤锅 / 炖菜","categoryDetail":"干锅牛肉","name":"顶顶牛特色干锅牦牛肉","address":"维也纳酒店附近","price":"人均70左右","note":"干锅牛肉很嫩 没怪味，我不吃牛肉的朋友都能吃里边的菜，红枣茶很好喝","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":97},{"id":"ab0bf032d41073","city":"大柴旦","region":"青海","district":"祁连县","category":"米饭 / 简餐","categoryDetail":"砂锅","name":"马小英砂锅","address":"维也纳酒店楼下","price":"人均45","tips":"分量超足可以少量多次的点 种类也很多 土豆泥拌饭！","note":"土豆泥永远的神 还有鸡爪也不错 超级糯","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":98},{"id":"df2cf135830dc8","city":"海东","region":"青海","district":"平安区","category":"米饭 / 简餐","categoryDetail":"柴火鸡","name":"新沁苑柴火鸡","address":"平安区马义新村","price":"人均50左右","tips":"是清真饭馆，店挺大的，是那种农家院，基本都是十人左右大桌","note":"巨巨巨巨巨巨好吃！！！强烈推荐，一定要吃宽粉，还可以另加花卷沾汁儿超级美味。是那种大锅现炒，基本都是辣的，不能吃辣的禾谨慎！可以选择辣度，微辣也很好吃。包间里会有麻将桌，还可以边吃边玩儿，不会赶人，老板人巨好，我们当时吃完饭纯打麻将玩儿了得有四个小时，他只进来问了一下我们还要不要热一下没吃完的肉；这家是真的，高中上学的时候吃过一次，到现在都很想念的味道","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":99},{"id":"7082e37f8efb96","city":"格尔木","region":"青海","district":"乐都区","category":"其他美食","categoryDetail":"手抓牛肉/椒麻鸡","name":"孔阿訇手抓王","address":"格尔木市金峰路维迩思酒店(原东哈宾馆)隔壁","price":"70-100","tips":"可以点精品手抓羊肉","note":"超级好吃的羊肉，我们打包回到酒店，冷了吃还特别好吃，一点膻味都没有","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":101},{"id":"0bf618e310bddf","city":"玉树藏族自治州","region":"青海","district":"结古镇","category":"甜品 / 饮品","categoryDetail":"青椒炒牦牛肉/本地酸奶/风干牛肉","name":"一般的藏餐厅都有","address":"地址待核验","price":"就十几块","tips":"要确定是牦牛肉而不是合成肉","note":"超级超级好吃卓沅就最喜欢吃青椒炒牦牛肉，牦牛肉炒的跟其他肉炒的真的不一样！","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":102},{"id":"8b11be5274907e","city":"格尔木","region":"青海","district":"德令哈市","category":"烧烤 / 烤肉","categoryDetail":"红柳肉串，虾尾，干锅翅中虾","name":"尕祈烤鱼","address":"博爱巷","price":"稍微有点小贵","tips":"清真店哦，凌晨也营业，虾尾我觉得超辣","note":"店里好多都挺好吃的，有兴趣的可以试试看","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":106},{"id":"b94e473f6a5650","city":"海北州","region":"青海","district":"门源县","category":"甜品 / 饮品","categoryDetail":"手工酸奶","name":"原味老酸奶","address":"御馨花都E区后门左面，过小年正对面的一个店","price":"价格3元5元及以上","tips":"清真店哦，一般3元的就可以","note":"真的真的很好吃，我一般想吃了就会买，我家里人也爱吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":107},{"id":"f2f5354f939d6c","city":"海北州","region":"青海","district":"门源县","category":"面食 / 米粉","categoryDetail":"米线","name":"川铭佬","address":"欣益小区西门南70米","price":"14元及以上","tips":"他们的香辣也不辣哦，一个人一人份的就够了，一般饭点人超级多的，服务员可能会声音有点大，但是不要害怕性格而已，无恶意","note":"在县城开的最久的一家米线店，是好吃的，不会踩雷，虽然不是本地人开的","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":108},{"id":"1209758fbbdea1","city":"州","region":"青海","district":"贵德县","category":"火锅 / 串串","categoryDetail":"火锅 干锅","name":"君念美食火锅城","address":"二号桥头","price":"干锅150左右","tips":"干锅两斤起做哦，四个人吃刚刚好的感觉","note":"干锅超级好吃！！！羊排虾、翅中虾都很绝，羊肉没有膻味，很爱","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":109},{"id":"b4bc787da58e9a","city":"海东","region":"青海","district":"乐都区","category":"其他美食","categoryDetail":"酿皮","name":"老作坊酿皮","address":"北门(可直接定位老作坊酿皮)","price":"一碗7元","tips":"早点去，下午太晚买完就不开门了","note":"手工酿皮味道很不错(里面有葱姜蒜，如果不吃可以提前说)；带到民勤给家禾们都尝尝","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":110},{"id":"a7da998379a624","city":"海东","region":"青海","district":"互助县","category":"米饭 / 简餐","categoryDetail":"土豆粉","name":"砂锅土豆粉","address":"南大街工商银行旁","price":"人均15","tips":"饭店特别小 饭点人超多 注意错峰","note":"里面麻辣会有点麻哦 不喜欢麻味的不要点 原味的就是微辣 我最爱！！","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":111},{"id":"a88de920e4ee53","city":"海东","region":"青海","district":"平安区","category":"素食","categoryDetail":"柴火鸡","name":"大团结柴火鸡","address":"我有点忘了，宝宝你们自己搜吧，总店是在平安，加盟店西宁湟中多吧都有","price":"套餐里200多里面有鸡肉鸡爪鸡胗还有素菜","tips":"不太适合一俩个人去吃，我和我朋友三个人去吃都吃不完，可以点个花卷","note":"里面一定要加宽粉！！！巨好吃套餐里的素菜可以换成你喜欢的","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":112},{"id":"899467fbdedfd3","city":"西宁","region":"青海","district":"城西区","category":"甜品 / 饮品","categoryDetail":"奶茶","name":"宁茶","address":"力盟商业街美食广场","price":"十几块钱","tips":"量很大","note":"蜜香牛乳茶，绝！","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":113},{"id":"6280f15bacf996","city":"西宁","region":"青海","district":"城西区","category":"面食 / 米粉","name":"手抓饼","address":"力盟商业街美食广场","price":"人均二十","tips":"清真店，饭点人多要排队，饼是现场擀现场烙的","note":"最基础版就很好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":114},{"id":"b1f6518099b292","city":"州","region":"青海","district":"贵德县","category":"其他美食","categoryDetail":"面食","name":"尕让面片","address":"尕让乡镇政府周边的面馆都不会踩雷","price":"人均20～30","tips":"清真店居多，不让外带食物","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":116},{"id":"22938278acc7f8","city":"西宁","region":"青海","district":"城西区","category":"甜品 / 饮品","categoryDetail":"玉树查拉牦牛酸奶","name":"牦牛酸奶","address":"力盟步行街有个茶百道边上","price":"15一小碗","tips":"纯牦牛酸奶，配料表很干净，可以尝一下，可能会有点酸，加糖就可以，听说现在好像有其他饮品","note":"推荐人参果牦牛酸奶","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":117},{"id":"07b440a0c38034","city":"海东","region":"青海","district":"平安区","category":"烧烤 / 烤肉","categoryDetail":"面食","name":"厨娘干煸炒面","address":"平安区古驿大道172","price":"20块左右","tips":"清真店，干煸炒面特别好吃，烧烤也好吃，记得提前说辣度","note":"干煸炒面，烧烤","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":118},{"id":"9dbd0d8f615ce4","city":"海东","region":"青海","district":"乐都区","category":"甜品 / 饮品","categoryDetail":"甜坯子","name":"老白家手工酸奶","address":"新乐大街亿家人商场对面","price":"一斤6元","tips":"没什么需要注意的，如果在那吃一碗3元","note":"基本放假都会去买，我感觉很好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":119},{"id":"833ce85e91de19","city":"海东","region":"青海","district":"乐都区","category":"面食 / 米粉","categoryDetail":"过桥米线","name":"鲜香聚过桥米线","address":"南门街小四川餐厅旁边10米左右","price":"一人份12元","tips":"人不是很多，一般去了就能吃","note":"很好吃！","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":120},{"id":"a02f4fe7ee7836","city":"海东","region":"青海","district":"乐都区","category":"面食 / 米粉","categoryDetail":"过桥米线","name":"云南过桥米线","address":"桥北路与新乐大街交叉口，在地底下","price":"一人份12元","tips":"地下城美食城店很多，饭点人比较多，可以避开中午12点，还有服装店美甲店等","note":"米线超好吃！和上一家不同的是这家店可以自己调料碗，很不错！","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":121},{"id":"e6c75fad0c3ab9","city":"西宁","region":"青海","district":"城西区","category":"其他美食","categoryDetail":"酿皮","name":"生莲酿皮","address":"海湖世通国际店，离海湖万达很近","price":"一碗（半张）9元","tips":"适合天气特别好的下午吃，不全是酿皮 梗皮、甜醅都有","note":"有韭菜和蒜水，不喜欢提前给老板说，不过这是灵魂哈哈哈","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":122},{"id":"09afaf35f14ac0","city":"德令哈","region":"青海","district":"德令哈市","category":"面食 / 米粉","categoryDetail":"砂锅 炒菜","name":"川味小排挡","address":"海西公园对面","price":"砂锅人均二十左右","tips":"饭店小，人多，尽量避开饭点","note":"什锦米线(里面有排骨，鸡块，小酥肉 腊肠什么，很好吃)，@然后炒排骨也好吃！","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":123},{"id":"d68415a0083744","city":"西宁","region":"青海","district":"大通县","category":"烧烤 / 烤肉","categoryDetail":"羊肉串 炮仗 面片","name":"西北农家烤肉庄","address":"三号桥媒苑小区对面","price":"一串两块五（上次去是这样的","tips":"晚上氛围好一点 量比较多 人少可以少点一点","note":"面片实话香 总体偏咸 但是本地人肯定能接受","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":125},{"id":"9e730f6edd7d9b","city":"格尔木","region":"青海","district":"大通县","category":"烧烤 / 烤肉","categoryDetail":"炕锅羊肉","name":"马一黑烤肉美食","address":"外卖（昆仑店）","price":"一份100左右","note":"羊肉没膻味，配菜也很丰富很好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":126},{"id":"822773bae7cd33","city":"西宁","region":"青海","district":"城北区","category":"面食 / 米粉","categoryDetail":"过桥米线","name":"营养过桥米线","address":"沈那中学旁边","price":"一份12","note":"吃了六年，真的好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":127},{"id":"03f7a410df2582","city":"西宁","region":"青海","district":"城东区","category":"面食 / 米粉","categoryDetail":"手抓羊肉","name":"伊航三品东乡手抓","address":"在新千夜市旁边","price":"一斤手抓羊肉42","tips":"面片也好吃，我们点的羊肉面片和干炒面片都很好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":128},{"id":"9750ea31659283","city":"西宁","region":"青海","district":"城东区","category":"面食 / 米粉","categoryDetail":"螺狮粉","name":"螺姑娘螺蛳粉","address":"在中惠万达四楼","price":"一份20","tips":"加炸蛋更好吃，还是清真的","note":"加炸蛋","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":129},{"id":"e5dedf3ad976e4","city":"黄南州","region":"青海","district":"尖扎县","category":"火锅 / 串串","categoryDetail":"麻辣烫","name":"姊妹麻辣烫","address":"在蜜雪冰城往下走200米就有","price":"人均20多","tips":"都好吃","note":"非常好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":130},{"id":"33839e3743193d","city":"海东","region":"青海","district":"民和县","category":"火锅 / 串串","categoryDetail":"麻辣烫","name":"毛丹花麻辣烫","address":"老市场直走100米","price":"人均20左右","tips":"味道跟普通的麻辣烫不一样，特别好吃","note":"对于爱吃麻辣烫的我绝了","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":131},{"id":"d6b0c897f7756e","city":"州","region":"青海","district":"贵德县","category":"火锅 / 串串","categoryDetail":"麻辣烫","name":"功夫麻辣烫","address":"建设银行那边","price":"点菜的","tips":"非常好吃 我从高中就开始吃 店员态度也非常好","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":132},{"id":"ab90d7a0e7ace6","city":"西宁","region":"青海","district":"城东区","category":"烧烤 / 烤肉","categoryDetail":"炕锅","name":"阿布炕锅烤肉美食．清真（新千店）","address":"城东区共和路新千国际广场14号楼1层14-04号","price":"人均五十左右","tips":"店还蛮多人的，建议提前到","note":"吃不惯羊肉牛肉，点的炕锅鸡，味道不错，服务也不错","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":133},{"id":"f6a7930403b0f2","city":"海西州","region":"青海","district":"格尔木市","category":"烧烤 / 烤肉","categoryDetail":"炕锅羊肉","name":"老字号老马炕锅烤肉城","address":"海西蒙古族藏族自治州格尔木市昆仑路街道建设中路(青海格尔木中浩希尔顿逸林酒店北侧约40米)","price":"两个人123","tips":"小包间，两个人很宽敞，四个人有点点挤","note":"炕锅羊肉很香，其他的正常口味（从察尔汗盐湖回来吃这个感觉香爆了哈哈哈","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":134},{"id":"dd79bd2b6f3b72","city":"西宁","region":"青海","district":"城东区","category":"面食 / 米粉","categoryDetail":"包子","name":"西北马家优质包子","address":"青海省西宁市城东区为民巷13号","price":"8个有荤有素18","tips":"离西宁站步行距离挺近，早餐点去要小小排队","note":"牛肉土豆馅好吃，其他的馅不太记得了应该是无功无过，胡萝卜 牛肉萝卜可尝！","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":135},{"id":"0dcf298f717668","city":"茫崖","region":"青海","district":"冷湖镇石油后街","category":"火锅 / 串串","categoryDetail":"类似火锅","name":"顶顶牛特色干锅牦牛肉店","address":"地址待核验","price":"人均60","tips":"在美团上抖音上团购点便宜","note":"吃的牛肉，肉非常多。蔬菜也很好吃（个人点的辣锅）","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":136},{"id":"41f84aa3e912b0","city":"全省/多地","region":"青海","district":"柴旦镇创新街","category":"火锅 / 串串","categoryDetail":"类似火锅","name":"绪和淳特色牦牛排锅店","address":"地址待核验","price":"人均60","tips":"在美团上抖音上团购点便宜","note":"吃的牛排非常嫩非常鲜美（个人点的清淡锅，汤非常好喝）","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":137},{"id":"4a67bbd1956c25","city":"州","region":"青海","district":"贵德县","category":"地方菜","categoryDetail":"炒菜（川菜）","name":"百杏小炒","address":"红盾小区门口","price":"人均50左右","note":"啥都好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":138},{"id":"5166ee57d77e6f","city":"西宁","region":"青海","district":"城中区","category":"其他美食","categoryDetail":"纸包鱼","name":"茂妹纸包鱼","address":"红星天铂三期门口","price":"人均50＋","note":"好吃，可以加菜，老板还会送汤","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":139},{"id":"a7850f84956b58","city":"西宁","region":"青海","district":"城东区","category":"其他美食","categoryDetail":"清真炒菜","name":"马佬爷伊荣小馆","address":"城东区中发源广场5楼","price":"人均40+","tips":"都很下饭、稍微有点辣","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":140},{"id":"55f0dc8515a52b","city":"海东","region":"青海","district":"乐都区","category":"其他美食","categoryDetail":"炒炮仗","name":"伊澜老炒炮仗","address":"秀水湾路口，城南医院隔壁","price":"14（面食不一样价格不一样）","tips":"本人很喜欢吃，加辣椒醋绝了","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":141},{"id":"0650d0a7e34fc7","city":"格尔木","region":"青海","district":"乐都区","category":"卤味 / 熟食","categoryDetail":"混沌","name":"红满缘混沌管","address":"世邦城市广场旁边","price":"人均20+","tips":"小卤味很棒，喜欢吃辣的可以吃麻辣混沌","note":"我觉得他家辣不辣都好吃","sourceSheet":"青海篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=kh9ny4","sourceRow":142}]