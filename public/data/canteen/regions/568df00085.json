[{"id":"1729da81da3674","city":"银川","region":"宁夏","district":"区域待补充","category":"火锅 / 串串","categoryDetail":"炸串","name":"爱·爱炸串串店(怡安小区西区店)","address":"宁夏银川市西夏区怀远西路576号","price":"人均20-30","tips":"一定要吃炸香蕉","note":"炸香蕉很灵魂","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":4},{"id":"f887a8be497ff3","city":"银川","region":"宁夏","district":"区域待补充","category":"烧烤 / 烤肉","categoryDetail":"烧烤","name":"新疆阿凡提烤羊肉串","address":"宁夏银川市金凤区福州北街天成好吃街","price":"烤羊排-6￥ 羊肉串-2.5￥","tips":"羊肉串买十送一哦","note":"羊排贼拉香 口感很好不老不膻 肥肉部分焦香焦香的 可以让老板烤焦一点","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":5},{"id":"7a08f8ff5bdeb6","city":"银川","region":"宁夏","district":"区域待补充","category":"烧烤 / 烤肉","categoryDetail":"烧烤","name":"果仁大面筋","address":"宁夏银川市金凤区福州北街天成好吃街","price":"面筋-4￥","tips":"老板比较冷淡 但是味道还不错 比较大一个的面筋","note":"面筋比较好吃 其他一般了就","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":6},{"id":"eff09d8d59c06f","city":"灵武","region":"宁夏","district":"区域待补充","category":"火锅 / 串串","categoryDetail":"麻辣烫","name":"辣妈干炒麻辣烫","address":"灵武市城市花园利民苑10号楼面东5号商业房","price":"20左右","tips":"干拌麻辣烫我说真的老好吃了","note":"不会描述但是真好吃","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":7},{"id":"b167fdf90c770b","city":"银川","region":"宁夏","district":"区域待补充","category":"其他美食","categoryDetail":"怀远辣条","name":"努尔麦（奴尔麦）","address":"宁夏怀远夜市（还有各个商超还有拼多多店、抖音店）","price":"超市5元一包","note":"油炸的不好吃（就是不辣的那种）我吃不了辣！但是蒜香的还是能接受几块儿。给很多朋友寄了蒜香、川香他们都很爱吃；现场有款比较软的，忘记是什么味的。好吃，不好带走，很好吃。","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":8},{"id":"a1d75defc28607","city":"银川","region":"宁夏","district":"区域待补充","category":"其他美食","categoryDetail":"羊杂碎","name":"保家羊杂","address":"正源街附近，具体忘了，等我查到了再来改一下","price":"小碗二十多吧大概","tips":"是老店，装修没那么精致","note":"放假回去必须吃一碗","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":9},{"id":"46f191499dbfde","city":"银川","region":"宁夏","district":"兴庆区","category":"火锅 / 串串","categoryDetail":"麻辣烫","name":"汉中小龙凉皮麻辣烫","address":"鼓楼那边 宁夏回族自治区银川市兴庆区文化街街道民生巷20号(义合旁边)","price":"盆烩12一份 凉皮啥的便宜","note":"好吃 特别香 非常能代表宁夏麻辣烫的味道 每次下班不知道吃啥就去他们家","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":11},{"id":"2154f675d1a332","city":"银川","region":"宁夏","district":"兴庆区","category":"火锅 / 串串","categoryDetail":"辣糊糊","name":"姐妹辣糊糊","address":"银川市兴庆区新华街姐妹辣糊糊","price":"人均50","note":"无油火锅 可以带干料回家煮；其他的等明天摸鱼再发；哇塞！这家去了超多次， 是我觉得银川最好吃的辣糊糊！；吃了好几次，虽然他们没有标注清真的，但是没有不清真的东西，而且真的好吃！辣辣的好吃！！吃不了太辣的也能吃！！！","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":12},{"id":"a1d8cfbf0f7f6c","city":"银川","region":"宁夏","district":"兴庆区","category":"早餐 / 小吃","categoryDetail":"小吃","name":"宁阳六哥","address":"西夏区宁阳负一","tips":"一定要吃烤猪蹄！！！（单价20一份）","note":"负一章鱼小丸子我的神！！！！！都给我去吃（烤馕旁边的）哪家烤馕旁边姐妹！！！；好吃！爱吃！鸡爪也好吃！！！！；真个真的绝！他们家羊肉串也嘎嘎香！；对面的杨梅酸枣汁！去喝！！！加冰！！！好喝！！！","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":13},{"id":"0cb77199799e90","city":"银川","region":"宁夏","district":"兴庆区","category":"其他美食","categoryDetail":"涮肚","name":"王记涮肚","address":"银川市西夏区怀远市场负一层","price":"忘记价格了 有姐妹可以补充 价格偏贵","note":"主打涮肚 酸酸辣辣的 很好吃 羊蹄也都是比较软烂 没有异味","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":14},{"id":"6117e7ea95d0a2","city":"银川","region":"宁夏","district":"兴庆区","category":"面食 / 米粉","categoryDetail":"米粉","name":"张记桂林米粉","address":"银川市西夏区怀远市场","price":"人均20","tips":"问清楚价格 价格较高属于 份量也是较小","note":"超爱酸辣笋尖米粉，酸酸辣辣的，大学四年吃了四年，现在想起来还会流口水；连锁店，金凤区万达金街的也好吃","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":15},{"id":"103a4969434cfe","city":"银川","region":"宁夏","district":"西夏区","category":"其他美食","name":"永居园大盘鸡","address":"银川市西夏区幸福巷店永居园大盘鸡","price":"小份69","note":"只吃过大盘鸡软软的爱吃辣的可以要加辣","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":16},{"id":"9508b7c96e66bb","city":"银川","region":"宁夏","district":"西夏区","category":"米饭 / 简餐","categoryDetail":"点菜","name":"金阳食府","address":"银川市西夏区兴洲街","price":"人均大概70多","note":"都挺好吃之前点了牛腩焖面，一个什么什么豆腐特别好吃","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":17},{"id":"92f71b93421014","city":"银川","region":"宁夏","district":"金凤区","category":"酒馆 / 夜宵","name":"蓝鲸鲜啤","address":"地址待核验","price":"人均50-70","tips":"人挺多要提前约位置","note":"好吃好吃好吃！！！！离开宁夏以后再也没吃到过这么好吃的店！精酿很好喝！！！！","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":19},{"id":"882daba00aa973","city":"银川","region":"宁夏","district":"兴庆区","category":"烧烤 / 烤肉","categoryDetail":"烧烤","name":"红柳枝滩羊烧烤","address":"兴庆区新一中文苑西巷","price":"五十左右","tips":"价格偏贵但是是真材实料，汉堡很好吃，薯条也爱吃","note":"都挺好吃的","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":20},{"id":"e1a624ece8b2b2","city":"银川","region":"宁夏","district":"兴庆区","category":"面食 / 米粉","categoryDetail":"粉","name":"一碗情深伤心粉","address":"新华街东方红对面小巷","price":"一碗10r可加两种菜","tips":"不好停车，会排队","note":"能吃辣必冲，清汤也很香！；这个老好吃了！！！！！能吃辣的强烈推荐。我喜欢吃面条。","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":21},{"id":"f0be9cd34737a8","city":"银川","region":"宁夏","district":"兴庆区","category":"其他美食","categoryDetail":"豌杂面","name":"自家红烧牛肉面","address":"银川市兴庆区解放西街","price":"人均20左右","note":"去之前饿了么看看开门没，爱豌杂","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":22},{"id":"b4c7b0b5ffbf8c","city":"银川","region":"宁夏","district":"兴庆区","category":"火锅 / 串串","categoryDetail":"麻辣烫、凉皮","name":"小王凉皮麻辣烫","address":"银川市金凤区庆丰街71号","price":"小碗7块大碗8块","note":"凉皮小王7块，大碗八块，加辣好吃。麻辣烫感觉盐有点多","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":23},{"id":"d1cb1dfcbdee51","city":"银川","region":"宁夏","district":"兴庆区","category":"早餐 / 小吃","name":"姐妹凉皮","address":"大武口","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":24},{"id":"a240d010fe32c2","city":"银川","region":"宁夏","district":"兴庆区","category":"面食 / 米粉","categoryDetail":"米线","name":"喵叔米线","address":"王府井旁边的朝阳巷里","price":"人均16-17","note":"我喜欢麻辣味 很香","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":25},{"id":"8f617fd8871fd2","city":"银川","region":"宁夏","district":"金凤区","category":"海鲜 / 河鲜","categoryDetail":"砂锅","name":"清真.马记一品砂锅总店","address":"金凤区北京中路51号","price":"20-40元","tips":"超级推荐","note":"酸菜牛肉砂锅，加香菜绝了！！带鱼砂锅也好吃！！麻辣大虾也是一绝！！！","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":26},{"id":"3743111c87ca7a","city":"银川","region":"宁夏","district":"兴庆区","category":"面食 / 米粉","categoryDetail":"螺蛳粉","name":"嗦螺记螺蛳粉","address":"中心巷（鼓楼附近）","price":"人均20以内","tips":"导航可以直接到，位置不太好找","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":27},{"id":"e671043fa5f8d5","city":"银川","region":"宁夏","district":"兴庆区","category":"面食 / 米粉","categoryDetail":"灌饼","name":"富二运鸡蛋灌饼","address":"银川二十中对面","price":"人均10以内","tips":"因为是早餐最好上午去，他们家经常饼卖光了就关门，下午或晚上去要看运气","note":"从初中吃到现在，全银川最好吃的灌饼！；二中附近也有一家，旁边的土豆片夹馍也很好吃！土豆脆脆的；他家鸡蛋灌饼真的超级好吃，就是在找有没有禾宝写这家，没有人写的话我一定会在下面加上的。他家营业时间好像是7：00—13：00，16：00—20：00，我一般会点+鸡肉肠+花干的，6.5元，强推！！！！！","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":28},{"id":"e286a5117afbf7","city":"银川","region":"宁夏","district":"金凤区","category":"汤锅 / 炖菜","categoryDetail":"砂锅","name":"嘉誉里砂锅","address":"湖畔嘉苑西门","price":"人均20及以上","tips":"平时人有点多，但味道不错，十几年老店，量也合适，如果是肉锅两个人点一个就够","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":29},{"id":"72d01e329108a6","city":"银川","region":"宁夏","district":"西夏区","category":"面食 / 米粉","categoryDetail":"小吃","name":"酥小蒙牛肉饼","address":"怀远夜市","price":"一个4.5r","tips":"下午四点多才会开门，晚上排队的人超级多，可以早点排队","note":"上过央视，或者算是网红小吃，但吃过还是不错的，一定要热着吃才好吃","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":31},{"id":"e65f35b210c31e","city":"银川","region":"宁夏","district":"西夏区","category":"面食 / 米粉","categoryDetail":"饼","name":"盛林记香辣土豆片夹馍（三中总店）","address":"兴庆区永康南巷与泽民巷交叉口南40m","price":"10r左右","tips":"注意节假日是否开门","note":"爱吃辣的而一定吃，要全家福！","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":32},{"id":"379a9e19a847d7","city":"银川","region":"宁夏","district":"金凤区","category":"烧烤 / 烤肉","categoryDetail":"烧烤","name":"秀红烧烤","address":"银川市金凤区良田镇市场","price":"面筋、考肠、年糕都2元鸡排4元","tips":"通常下午晚上在良田镇市场入口处，最好来的时候是在每月的日期以3、6、9结尾的市集来。","note":"超级好吃，料足还便宜","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":33},{"id":"f272aeaa21aa62","city":"银川","region":"宁夏","district":"金凤区","category":"其他美食","categoryDetail":"羊肉手抓","name":"国强手抓（贵宾楼店）","address":"宁夏回族自治区银川市金凤区上海西路与尹家渠北街交口金海明月花园四号","tips":"一定要早去，中午是11点开始点菜。晚了水煮肋排就卖没了","note":"烤的没有煮的好吃，还有个炒莴苣也好吃！；很好吃！我最喜欢吃烫面油香➕手撕包菜➕羊肉手抓，我觉得凉拌枸杞苗不好吃","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":34},{"id":"263e5f7da7b890","city":"银川","region":"宁夏","district":"兴庆区","category":"烧烤 / 烤肉","categoryDetail":"烧烤","name":"亚顺烧烤","address":"玉皇阁附近，新宁巷","price":"人均70+","tips":"下午五点半开餐，包厢可能需要提前打电话定位置","note":"银川数一数二的烧烤了，肉类完全不踩雷，捞汁类也很好吃，而且在银川算比较便宜的，性价比超高","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":38},{"id":"c0251b9b8316eb","city":"银川","region":"宁夏","district":"金凤区","category":"其他美食","categoryDetail":"辣糊糊","name":"塞尚海宝辣糊糊","address":"金凤区康居A2-32号楼-7号营业房","price":"人均60+","tips":"可以让老板给你调蘸料很好吃！！！！","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":39},{"id":"8cb51e176dd66c","city":"银川","region":"宁夏","district":"兴庆区","category":"海鲜 / 河鲜","categoryDetail":"塔吉锅鱼虾套餐香辣味","name":"塔吉锅","address":"鼓楼ccmal四楼","price":"套餐共62","tips":"自己选菜，可以在美团上团购，然后看可以自选几个菜，不过最推荐鱼虾套餐香辣味，米饭都是自己舀，无限量的，","note":"有一点偏咸辣，吃完可能会想要多喝点水哈哈哈哈。但是很有性价比","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":40},{"id":"e9086cbc345b2d","city":"银川","region":"宁夏","district":"金凤区","category":"面食 / 米粉","categoryDetail":"过桥米线","name":"尚牛家","address":"金凤区庆丰街287号（导航可以搜到","price":"10+","tips":"老板比较抠搜，服务态度也一般但是真的好吃","note":"10元基础锅，然后自己用小碗调辣椒醋之类的，他家的肉丸、鸡爪、卤蛋也都很好吃，饭点人都很多","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":41},{"id":"c0c57f9fb2db33","city":"银川","region":"宁夏","district":"西夏区","category":"其他美食","categoryDetail":"炒菜","name":"花雕鸡","address":"怀远路西夏万达斜对面","price":"2-3人80（美团）有团购","note":"能吃辣就加辣，","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":42},{"id":"a7853d87d4a90b","city":"银川","region":"宁夏","district":"兴庆区","category":"其他美食","categoryDetail":"炒菜","name":"李燕特色炒烩肉","address":"兴庆区南关清真寺玉皇阁南街303号","price":"人均40","tips":"人有时候很多。也可以点外卖，稍微比店里面贵一点。旁边那家的炒烩肉也好吃","note":"炒烩肉好吃，送羊肉汤。两个人点半斤就行，单独点个其他的菜","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":43},{"id":"6653690885c9d8","city":"银川","region":"宁夏","district":"西夏区","category":"烧烤 / 烤肉","categoryDetail":"烤串","name":"烤鸡蛋","address":"西夏区怀远夜市","price":"五块一串","tips":"有一个摊和一个门面店， 是一家店，都好吃","note":"经典烤鸡蛋，真的超好吃，带我四川同学去吃 她也觉得超好吃的程度","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":44},{"id":"de4264be214e41","city":"银川","region":"宁夏","district":"兴庆区","category":"面食 / 米粉","categoryDetail":"螺蛳粉","name":"玖螺螺蛳粉","address":"吾悦广场金街一楼渔粉叔叔旁边","price":"人均15左右","tips":"给不爱吃辣的家禾推荐番茄口味的不加辣，再加一个炸蛋","note":"如果很爱吃腐竹的家禾可以单加一份腐竹，腐竹个人觉得量有点多，可能会吃不完","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":45},{"id":"0825d9211c453d","city":"银川","region":"宁夏","district":"兴庆区","category":"火锅 / 串串","categoryDetail":"火锅","name":"愚人火锅·清真（大新家园店）","address":"兴庆区丽景街街道友爱街与北京东路交叉口东北角","price":"人均46","tips":"饭店人可能会有点多","note":"团购两人餐132，量很大，可能会吃不完","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":46},{"id":"ee65fa81ecb5f1","city":"银川","region":"宁夏","district":"兴庆区","category":"其他美食","categoryDetail":"八宝茶","name":"德兴舍八宝茶","address":"银川市金凤区长城花园西区374号","price":"一般6r/包","tips":"有不同价格的八宝茶，买六块钱那个就行！大家一般都选那个规格的","note":"里面有一个酱包是玫瑰的，越喝味道越浓，怕甜的话可以少放一点糖，很适合当手信","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":48},{"id":"45903109081378","city":"银川","region":"宁夏","district":"兴庆区","category":"火锅 / 串串","categoryDetail":"麻辣烫、米线","name":"冉冉麻辣烫","address":"银川市金凤区北京路贸易巷","price":"人均15-20","tips":"麻辣烫和炒米线都好吃！","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":49},{"id":"00778f2b238951","city":"银川","region":"宁夏","district":"金凤区","category":"早餐 / 小吃","categoryDetail":"烩肉","name":"老马家烩肉","address":"金凤区福州南街","price":"人均25起","tips":"肉很好吃，尤其是汤很好喝，可以尝试一下汤泡饭","note":"从小吃到大，来银川的时候就在那开着了","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":50},{"id":"fcb76ea5dde24c","city":"银川","region":"宁夏","district":"贺兰县","category":"面食 / 米粉","categoryDetail":"土豆片夹馍","name":"盛林记香辣土豆片夹馍贺兰店","address":"银河东路与教育巷交叉口西40米","price":"人均15","note":"便宜好吃，多加辣椒，加鸡蛋，鸡蛋黄融化在那个辣汁里非常好吃；哈哈这家我出门走两步就到；好巧 我也是","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":52},{"id":"77ae833f679afb","city":"银川","region":"宁夏","district":"金凤区","category":"火锅 / 串串","categoryDetail":"麻辣烫","name":"益发顺麻辣烫","address":"火车站旁边的联华联小区","price":"20","tips":"麻辣烫好吃，干拌不推荐","note":"可以多辣","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":53},{"id":"7049024f6387b6","city":"银川","region":"宁夏","district":"金凤区","category":"米饭 / 简餐","categoryDetail":"手抓羊肉","name":"古味餐厅(福州南街店)","address":"银川福州步行街30号","price":"108一斤","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":55},{"id":"55e07b0db93fff","city":"贺兰县","region":"宁夏","district":"金凤区","category":"火锅 / 串串","categoryDetail":"辣糊糊串串","name":"瑞瑞串串","address":"贺兰县步行街","price":"所有的串都是一块钱！！！不管大小 她家都是很标准的串！！！","tips":"有可能会不开门比如下雨天或者其他情况 但一般都是开门的 需与学生错峰","note":"他家的辣糊糊辣度较辣 我一般选全是糊糊的 也可以加麻酱；他家真的好好吃的","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":56},{"id":"e5c38639773c45","city":"银川","region":"宁夏","district":"金凤区","category":"其他美食","categoryDetail":"手抓、烩菜","name":"马福财手抓","address":"通达街和上海路交叉口 往上海路走","price":"人均50左右","tips":"清真且美团有团购","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":57},{"id":"d75f9a29b53a38","city":"银川","region":"宁夏","district":"贺兰县金贵镇","category":"火锅 / 串串","categoryDetail":"凉皮、凉面","name":"网红麻辣烫","address":"贺兰县金贵镇集贸市场汉佐路与保南路交叉路口往西约五十米","price":"凉皮7块，凉面也是7块。可以，凉面，凉皮都加一点。味道会更好。","tips":"是清真的很多人都会吃，吃了都说挺好的。","note":"我个人感觉很好吃，我喜欢吃他家的凉皮和凉面，有时候两个我都会掺在一起吃。；这家纯网红店，说实话味道一般，如果去了可以吃，但没有必要专门去吃，就是一些菜粉之类的 菜类很少","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":58},{"id":"f829b046954b9d","city":"银川","region":"宁夏","district":"西夏区","category":"火锅 / 串串","categoryDetail":"火锅","name":"恋摊摊火锅","address":"怀远夜市","price":"人均60","tips":"清真有团购（个人觉得单点比较好）","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":59},{"id":"92479a9c5c76dc","city":"银川","region":"宁夏","district":"西夏区","category":"汤锅 / 炖菜","categoryDetail":"东北黏糊砂锅面","name":"暖砂局东北黏糊砂锅面","address":"西夏区宁阳广场负一层E62-E63号","price":"人均10元起","tips":"巨巨巨好吃，就和东北的味道一模一样，尤其是砂锅玉米面，贼黏糊（但不是清真的！）","note":"这家店是新开的，目前优惠巨多，我连续吃了好几天了！酸甜辣的！","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":60},{"id":"2ba21dd5862f75","city":"银川","region":"宁夏","district":"金凤区","category":"烧烤 / 烤肉","categoryDetail":"烤肉","name":"熙珍烤肉","address":"新昌东路民生东门 有好几家总店在唐徕","price":"人均50起","tips":"感觉银川最好吃的清真烤肉，他们家分量还可以，味道也好吃，推荐烤菠萝，五花真的很绝","note":"超级推荐 没事就去吃一顿，几家店都去过 口味没啥差，他家羊羊卷每次必点，提前手机排队","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":61},{"id":"d3dcd2904a61e2","city":"银川","region":"宁夏","district":"灵武市","category":"火锅 / 串串","categoryDetail":"麻辣烫","name":"术萍凉皮麻辣烫","address":"南关清真寺向北大概500米，一建七区小区楼下有个麻辣烫，小小的房子，真的好吃又量大","price":"10元起","tips":"清真，如果不喜欢太麻提前说少麻，10块钱的麻辣烫已经很少了，而且量蛮多的","note":"比较偏麻，但是真的很香","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":62},{"id":"b94907fb940009","city":"银川","region":"宁夏","district":"兴庆区","category":"烧烤 / 烤肉","categoryDetail":"烤肉","name":"西塔老太太泥炉烤肉","address":"阅海商场","price":"100起","tips":"烤肉很好吃，最喜欢土豆泥，不限量","note":"经常吃，味道很好，连锁店","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":63},{"id":"20d99686af6dea","city":"银川","region":"宁夏","district":"金凤区","category":"面食 / 米粉","categoryDetail":"螺蛳粉","name":"融柳大铁牛螺蛳粉","address":"塔渠街","price":"人均25","tips":"店面比较小，位置比较难抢","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":64},{"id":"7c142da3e1e972","city":"银川","region":"宁夏","district":"兴庆区","category":"面食 / 米粉","categoryDetail":"烤冷面，煎饼果子","name":"智飞小吃店(五谷杂粮煎饼)","address":"石油城嗨购吃货天堂＋（旁边巷子里智飞小吃店）","price":"基础套餐7元","tips":"早上只卖煎饼果子","note":"这家辣椒有点辣，能吃辣的一定要加辣，超好吃","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":65},{"id":"649c92203ece01","city":"银川","region":"宁夏","district":"兴庆区","category":"海鲜 / 河鲜","categoryDetail":"鸡爪 虾 鸡翅 螃蟹","name":"蒋哥肉蟹煲","address":"兴庆万达广场","price":"人均59","tips":"在商场内正常时间开放","note":"超超超超超好吃！不能吃辣的有福了","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":67},{"id":"1f528561c285fd","city":"银川","region":"宁夏","district":"西夏区","category":"面食 / 米粉","categoryDetail":"小吃","name":"小强土豆饼","address":"怀远市场","price":"4块一个","tips":"！强推给每一位来银川的家禾！ 一定要看清门头是这个名字 临近的一家也叫土豆饼 味道天壤之别 真的很好吃 不好吃可以打我","note":"可以选择辣跟五香 一般下午三四点才会营业吧","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":68},{"id":"227dba65d2dc0e","city":"银川","region":"宁夏","district":"金凤区","category":"火锅 / 串串","categoryDetail":"火锅 干锅","name":"红满堂炝锅鱼火锅(丽园店)","address":"北京中路街道黄河东路丽园巷34号营业房(近丽园小区)","tips":"干锅有团购 火锅没有团购 团购到店可以点","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":69},{"id":"42c13111dfb3ff","city":"银川","region":"宁夏","district":"西夏区","category":"其他美食","categoryDetail":"烤面筋","name":"源源烤面筋","address":"宁阳负一楼","price":"4元（好像）","tips":"建议下午去，人少，晚上人多要排队！","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":70},{"id":"fa9789ef692a87","city":"银川","region":"宁夏","district":"西夏区","category":"其他美食","categoryDetail":"炸串","name":"两人故事炸串屋","address":"银川市西夏区文萃北街宁阳文化商业广场D区-一层118室","tips":"清真","note":"好吃推荐！","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":72},{"id":"bf9a10f3cf1577","city":"银川","region":"宁夏","district":"西夏区","category":"烧烤 / 烤肉","categoryDetail":"烤串","name":"貳来地摊烧烤","address":"老柴油机场","tips":"清真","note":"自己烤的有体验感","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":73},{"id":"5c45f4ae5890f2","city":"银川","region":"宁夏","district":"兴庆区","category":"西餐","categoryDetail":"漂亮饭","name":"小桃李","address":"兴庆区书院东巷","price":"人均七八十","note":"漂亮又好吃的的饭，强推意面，几种都很好吃，周围环境也很好，适合拍照闲聊；求聚餐推荐好地儿","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":74},{"id":"b9e57b1a57dbec","city":"银川","region":"宁夏","district":"金凤区","category":"面食 / 米粉","categoryDetail":"螺蛳粉","name":"老柳州地摊螺蛳粉","address":"金凤区新华西街740号","price":"人均20～25","tips":"闭眼吃，没注意是否清真（欢迎补充或更改）","note":"爱吃螺蛳粉的我，觉得这家味道好正，隔壁糖水铺阿姨人也好好！","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":75},{"id":"ee753065f74750","city":"银川","region":"宁夏","district":"兴庆区","category":"其他美食","categoryDetail":"辣糊糊","name":"雷记辣糊糊","address":"民族街209号","price":"人均20","tips":"银川最好吃的辣糊糊！！我在外地都会微信买底料","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":76},{"id":"2b66f582093779","city":"银川","region":"宁夏","district":"西夏区","category":"其他美食","categoryDetail":"炸串、辣糊糊牛筋面","name":"享美味炸串","address":"西夏小区里面","price":"15-20","tips":"建议晚上稍微早点去 座位不太多而且人多时候等饭要40分钟","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":77},{"id":"9edfc44a0ed340","city":"银川","region":"宁夏","district":"西夏区","category":"米饭 / 简餐","categoryDetail":"炒菜","name":"小小酒家","address":"宁夏大学附近","price":"均价40","tips":"份量很大 手撕包菜我每次都吃","note":"上大学经常每个星期至少两次","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":78},{"id":"c67dd9b68d7483","city":"银川","region":"宁夏","district":"兴庆区","category":"其他美食","categoryDetail":"大盘鸡","name":"二哥辣炒小公鸡","address":"丰收巷颐和家园","price":"人均30","tips":"大盘鸡强烈推荐！！","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":79},{"id":"7953fe8b63ee4b","city":"石嘴山","region":"宁夏","district":"兴庆区","category":"面食 / 米粉","categoryDetail":"酸辣粉、馄饨","name":"爱家凉皮店","address":"宁夏石嘴山大武口光明中学附近","price":"人均10块","tips":"周一到周五饭点学生比较多，可以错峰","note":"物美价廉，学生时代经常吃的灵魂小店，混沌皮薄馅大，酸辣粉酸酸辣辣超级开胃，饭量小的朋友一定要小份，因为他们家大份是铁盆装！！！","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":85},{"id":"8004f436e687d4","city":"石嘴山","region":"宁夏","district":"兴庆区","category":"面食 / 米粉","categoryDetail":"干拌粉、肉夹馍","name":"正宗潼关肉夹馍","address":"宁夏石嘴山大武口永康南路","price":"人均20","tips":"店小 且中午会休息 可以在外卖软件上搜一下打电话问问 姐妹们切勿跑空哦","note":"干拌粉+潼关肥瘦肉夹馍，超级好吃！！！他们家辣椒比较辣，干拌粉推荐少辣多麻酱，肉夹馍是一层层酥皮那种的 ， 咬一口直接掉渣，超级香～","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":86},{"id":"787255e9bb2f75","city":"大武口","region":"宁夏","district":"兴庆区","category":"其他美食","categoryDetail":"辣糊糊","name":"碎嘴子辣糊糊","address":"体育场32号","price":"人均20-30吃到撑","tips":"一般不关门","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":88},{"id":"bff9594d020f94","city":"石嘴山","region":"宁夏","district":"平罗县","category":"面食 / 米粉","categoryDetail":"小吃","name":"姐妹炸串","address":"宁夏石嘴山市大武口区百花市场","price":"人均20-30","tips":"饭点需要排队半小时左右","note":"一定要吃炸茄盒（纯素），夹饼的话推荐鸡蛋+菜卷+素鸡+茄盒","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":90},{"id":"51cbe5821fc00e","city":"石嘴山","region":"宁夏","district":"大武口区","category":"早餐 / 小吃","categoryDetail":"小吃","name":"龚记狼牙土豆","address":"宁夏回族自治区石嘴山市大武口区台湾北路206号","price":"人均10元","tips":"是一家学校对面的小吃店，老板娘人超级好，但是周末偶尔会不开门","note":"尝试土豆年糕双拼个，多加点醋，超级香，土豆香香糯糯的，超级入味；在三中对面 开了好多年了 从上高一就开始吃 不过现在越来越贵了","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":91},{"id":"b626602605058c","city":"石嘴山","region":"宁夏","district":"大武口区","category":"面食 / 米粉","categoryDetail":"汉系炒菜","name":"一乡一味家常菜馆","address":"石嘴山市大武口区永康南路","price":"人均50左右","tips":"营业时间9.30-14.00 16.30-9.00","note":"来吃饭的家禾们可以找前台交换物料，前台小姐姐是同好，可以打折哟~；汗蒸茼蒿，苦菜拼沙葱，酱香牛腱，浇汁耳丝，风味茄子，乡味炒鸡，黑豆烧猪尾，芸豆猪蹄，火烧馍配青椒酱都超级好吃！（ps:青椒酱真的绝了，我爱青椒酱，蘸啥都好吃！）","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":92},{"id":"1050f9a38bc4d8","city":"石嘴山","region":"宁夏","district":"大武口","category":"火锅 / 串串","categoryDetail":"火锅","name":"粥底火锅","address":"永康花园对面","price":"人均40+","tips":"美团可以团卷","note":"如果人多去吃可以团卷 ，一两个人当场点单，点个小锅绝对够吃；他家有飞i饼，每个口味都很好吃","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":93},{"id":"1ab4310a137b6c","city":"石嘴山","region":"宁夏","district":"惠农区","category":"其他美食","categoryDetail":"酸辣粉","name":"够味酸辣粉","address":"东大街东胜院2-11","price":"人均10+","tips":"饭点人超多","note":"正常酸，正常辣","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":94},{"id":"0cb73ea6d97aa7","city":"石嘴山","region":"宁夏","district":"惠农区","category":"烧烤 / 烤肉","categoryDetail":"烧烤","name":"阿罗烧烤园","address":"惠农区惠裕路61西南方向80米吉运88","tips":"晚上早点去，人很多，店也不大","note":"我真的太爱吃烧烤了，有的会比较咸，吃完狂喝水，他家不咸，味道也很好，有个烤鲤鱼听说是老板自己去钓的，但是我个人不爱吃鱼，刺太多了，宁夏的烧烤有辣爆，外地没有的，辣爆必点！！","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":96},{"id":"4a5946db1c3069","city":"石嘴山","region":"宁夏","district":"大武口区","category":"面食 / 米粉","categoryDetail":"寿司","name":"哇塞寿司","address":"石嘴山市第九中学","price":"32元两人份，超大一盘","tips":"是一个比较小的店，可以选择带走吃哦","note":"樱花寿司真的超好吃，辣椒饼也好吃","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":97},{"id":"f658ded008258d","city":"大武口","region":"宁夏","district":"大武口","category":"早餐 / 小吃","categoryDetail":"凉皮","name":"姐妹凉皮","address":"步行街佰德隆附近","price":"9块","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":99},{"id":"ef848dfa4f4115","city":"石嘴山","region":"宁夏","district":"大武口","category":"其他美食","categoryDetail":"酸辣粉","name":"佳味多酸辣粉","address":"步行街","price":"人均10+","tips":"人有点多 但是是正宗重庆人开的店","note":"酸辣粉有点辣 炸串也不错","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":100},{"id":"79ff7b1b2052f5","city":"石嘴山","region":"宁夏","district":"大武口区","category":"其他美食","categoryDetail":"辣糊糊","name":"茶物语","address":"游艺西街578号","price":"10元左右一个人","tips":"最好错开高中学生放学时间 就在三中侧门","note":"饭量小的女生7、8块钱就够吃了 量很足 就是可能会有些慢；特别特别好吃啊 高中吃了三年现在大学了每次放假回去还是要跑去吃","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":101},{"id":"87e66b8fc08af7","city":"石嘴山","region":"宁夏","district":"大武口","category":"其他美食","categoryDetail":"朝鲜面","name":"正宗朝鲜牛肉面","address":"步行街","price":"人均10r","tips":"饭点人多","note":"热面冷面都好吃","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":102},{"id":"5056dac1fc9972","city":"石嘴山","region":"宁夏","district":"大武口区","category":"其他美食","categoryDetail":"辣糊糊","name":"体育场老太太","address":"体育场左手边","price":"人均30-40左右（含锅底）","tips":"饭点人可能多点","note":"蘸料有一个挺辣，味道不错","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":103},{"id":"025889226e0d98","city":"石嘴山","region":"宁夏","district":"平罗县","category":"火锅 / 串串","categoryDetail":"串串","name":"苏兵撸串吧","address":"星海花园南门向东走大概200米","price":"10元起","tips":"毛串➕炸串，从上学一直吃，特别喜欢，味道挺好的","note":"经常吃，非常喜欢，非常赞","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":104},{"id":"3126eb73e602c0","city":"石嘴山","region":"宁夏","district":"平罗县","category":"面食 / 米粉","categoryDetail":"肉饼","name":"优味客","address":"平罗中学南门对面","price":"6元","tips":"鸡肉饼，烤肠饼，味道特别好，酱料独有的","note":"上学一直吃，现在每次回去也会吃","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":105},{"id":"df42997cc561a7","city":"石嘴山","region":"宁夏","district":"平罗县","category":"其他美食","categoryDetail":"羊羔肉","name":"周大正宗爆炒羊羔肉","address":"石嘴山市平罗县黄渠桥镇新市场斜对面","price":"人均50","tips":"羊羔肉按斤点餐，随餐赠送一份糖麻丫贼好吃","note":"羊羔肉、八宝茶","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":107},{"id":"0239d55135eb97","city":"石嘴山","region":"宁夏","district":"大武口","category":"火锅 / 串串","categoryDetail":"辣糊糊火锅","name":"顶顶香辣糊糊","address":"石嘴山市体育场","price":"人均三十左右","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":108},{"id":"eae676e07bb145","city":"石嘴山","region":"宁夏","district":"大武口","category":"火锅 / 串串","categoryDetail":"火锅","name":"大掌柜火锅店","address":"大武口区悦荷足道3层","price":"50","tips":"正宗内蒙牛羊肉，还有罐罐茶可以喝","note":"羊蝎子也很不错","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":109},{"id":"28149e215229a9","city":"吴忠","region":"宁夏","district":"利通区","category":"早餐 / 小吃","categoryDetail":"凉皮","name":"亿家香凉皮","address":"吴忠中学店","price":"9元","note":"回吴忠必吃的","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":122},{"id":"0687ee085becd2","city":"吴忠","region":"宁夏","district":"青铜峡","category":"面食 / 米粉","categoryDetail":"米线","name":"过桥米线","address":"步行街北路口 胖子水果店旁边","price":"人均10元","tips":"点小人多 好好吃","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":125},{"id":"9a69237f47ad18","city":"吴忠","region":"宁夏","district":"利通区","category":"火锅 / 串串","categoryDetail":"火锅","name":"牛市坎火锅","address":"宁夏回族自治区吴忠市利通区汽车站店","price":"两个人一百多左右","tips":"下午饭点要提前一个多小时去排队，人很多","note":"里面的饮品吃火锅必点，鸳鸯锅必点一个辣的，超级好吃，蘸料也可以自己调","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":126},{"id":"ff0c701f199fc4","city":"吴忠","region":"宁夏","district":"利通区","category":"其他美食","categoryDetail":"羊杂","name":"杜优素羊杂","address":"黄河路店（新店）司机师傅都知道","price":"两人一百左右","tips":"老店比新店好吃，推荐新店是因为串导去那打过卡 补充：十勤团综时去过，节假日周末排队很久","note":"如果不打卡，纯为吃羊杂的话推荐去老杜家羊杂，他们家可以选择半肺半肚之类的；适合拍照打卡，很多明星都去过","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":127},{"id":"8e0582709b4383","city":"吴忠","region":"宁夏","district":"盐池县","category":"火锅 / 串串","categoryDetail":"麻辣烫、凉皮（肝子）","name":"胖子凉皮","address":"花马池镇盐池商城对面","price":"不贵的，一份十多块钱","tips":"要自己取餐，","note":"很好吃，每次回家必吃，分量正常，里面会默认加香菜和葱，不吃的要提前说哦","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":128},{"id":"37d1cc72b94e1e","city":"吴忠","region":"宁夏","district":"利通区","category":"甜品 / 饮品","categoryDetail":"面包甜点","name":"谷香斋","address":"胜利东街","price":"人均三十","tips":"下午人多一点","note":"他们家吃着一点都不腻","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":129},{"id":"1ebb8984b98ece","city":"吴忠","region":"宁夏","district":"利通区","category":"烧烤 / 烤肉","categoryDetail":"烧烤","name":"七野烧烤","address":"财满街","price":"牛羊肉串1块钱一串性价比极高","tips":"门口停车费劲","note":"有时候有点咸，建议给老板说味道淡一点","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":130},{"id":"66e06c6f0fec92","city":"吴忠","region":"宁夏","district":"利通区","category":"面食 / 米粉","categoryDetail":"夹菜饼","name":"地瓜坊","address":"吴忠中学对面","price":"拉满不超10","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":131},{"id":"5031dd5f0cc32f","city":"吴忠","region":"宁夏","district":"青铜峡","category":"火锅 / 串串","categoryDetail":"辣糊糊","name":"锦天顺辣糊糊","address":"永丰北街","price":"两个人六七十左右","tips":"可以提前在抖音团购锅底","note":"种类很多 强烈推荐牛筋面 吸满汤汁超级好吃！！！","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":132},{"id":"7db7664bd64526","city":"吴忠","region":"宁夏","district":"利通区","category":"火锅 / 串串","categoryDetail":"麻辣烫","name":"马金龙麻辣烫","address":"利通区民生巷丰宁街125号","price":"19元一斤","tips":"自选菜，沾汁免费","note":"微辣汤好喝","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":133},{"id":"06ab843f6695bf","city":"吴忠","region":"宁夏","district":"青铜峡","category":"火锅 / 串串","categoryDetail":"干炒麻辣烫","name":"回味麻辣烫（清真）","address":"碧水蓝天小区南门","price":"人均15","tips":"干炒麻辣烫超香！炒凉皮有点油有点腻","note":"ps禾伙人来银川可以找我一起玩！！！！；13209686239","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":134},{"id":"96708ec0ebd1ab","city":"吴忠","region":"宁夏","district":"青铜峡","category":"面食 / 米粉","categoryDetail":"早茶","name":"马伊饭庄","address":"吴忠有四家直营店","price":"人均30","note":"他家玻璃碗拌面非常好吃，料很足","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":135},{"id":"67a74afd2800db","city":"吴忠","region":"宁夏","district":"青铜峡","category":"烧烤 / 烤肉","categoryDetail":"烧烤","name":