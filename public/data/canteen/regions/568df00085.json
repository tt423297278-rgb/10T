?tab=1xgocf","sourceRow":147},{"id":"7727086abcbcda","city":"吴忠","region":"宁夏","district":"利通区","category":"早餐 / 小吃","categoryDetail":"早茶","name":"精致牛肉面","address":"利通区朝阳西路15-16号","tips":"蒸艾好吃","note":"环境好，品种较多","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":148},{"id":"97df963b84ea5f","city":"吴忠","region":"宁夏","district":"利通区","category":"其他美食","categoryDetail":"玉米面/酸辣粉","name":"亿家香","address":"门口有两个大黄蜂的幼儿园向前走过一个红路灯","price":"8","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":149},{"id":"0fe37e775849d7","city":"吴忠","region":"宁夏","district":"盐池","category":"火锅 / 串串","categoryDetail":"麻辣烫","name":"汉中麻辣烫","address":"花马池市场东门对面","price":"10","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":150},{"id":"c4de1cf4774d51","city":"吴忠","region":"宁夏","district":"盐池县","category":"酒馆 / 夜宵","categoryDetail":"夜市","name":"夜市羊蹄羊头等","address":"花马池市场北门一直往前走","price":"12到15","tips":"一点都不腥，非常好吃！！！","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":151},{"id":"6c8dd17126f0ef","city":"中卫","region":"宁夏","district":"沙坡头区","category":"其他美食","categoryDetail":"面","name":"桂花香手工面","address":"沙坡头区中山街","price":"人均10元","note":"非遗扁豆子面很好吃","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":161},{"id":"4f9963079e27d5","city":"中卫","region":"宁夏","district":"沙坡头区","category":"其他美食","categoryDetail":"炒拉条","name":"陈大强炒肚丝","address":"中山街商城夜市","price":"人均20","tips":"下午开，晚上人比较多","note":"他家炒肚丝和炒拉条都好吃，看着红但是很香，不是很辣","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":163},{"id":"c9f9f336d5fc39","city":"中卫","region":"宁夏","district":"沙坡头区","category":"火锅 / 串串","categoryDetail":"麻辣烫","name":"晓玲麻辣烫","address":"中山街","price":"人均15","tips":"饭点人很多，可能等餐时间会有点久，有免费的粥可以喝","note":"麻辣烫（是红汤不加牛奶和麻汁的那种），凉皮，炒宽粉都很好吃","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":164},{"id":"81351f4a3eb160","city":"中卫","region":"宁夏","district":"沙坡头区","category":"其他美食","categoryDetail":"特色炒刀削","name":"袁记特色炒刀削","address":"雍楼步行街","price":"人均15","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":166},{"id":"f8df5639e64637","city":"中卫","region":"宁夏","district":"沙坡头区","category":"火锅 / 串串","categoryDetail":"火锅","name":"麻辣因子火锅","address":"世和新天地","price":"人均45","tips":"饭点人很多，可以早点去排队，服务超级周到，跟海底捞很像","note":"推荐番茄锅，他家番茄锅会加枸杞原浆味道很特别也很养生","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":168},{"id":"f980f6f399591e","city":"中卫","region":"宁夏","district":"沙坡头区","category":"其他美食","categoryDetail":"猪藏","name":"张氏猪藏","address":"雍楼步行街","price":"人均15","note":"多放点洋葱，肥肉吃多会腻，","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":169},{"id":"94d10cf9622b48","city":"中卫","region":"宁夏","district":"沙坡头区","category":"其他美食","categoryDetail":"特色蒿子面","name":"桂花香手工面","address":"鼓楼","price":"人均10","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":170},{"id":"96894a09e14b22","city":"中卫","region":"宁夏","district":"沙坡头区","category":"其他美食","categoryDetail":"辣糊糊","name":"满口香辣糊糊","address":"二小门口","price":"人均10","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":172},{"id":"c76b2d59a03bbc","city":"中卫","region":"宁夏","district":"沙坡头区","category":"烧烤 / 烤肉","categoryDetail":"烤肉","name":"围炉烤肉","address":"世和新天地","price":"人均40","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":173},{"id":"7d2ef2d27e65c7","city":"中卫","region":"宁夏","district":"沙坡头区","category":"面食 / 米粉","categoryDetail":"饼子","name":"姐妹包饼店","address":"一中门口","price":"人均5","tips":"下午放学期间人很多需要排队（18.00-19.00）","note":"辣饼子或咸饼子夹大辣片，饼皮夹土豆丝。量大实惠","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":175},{"id":"2d05c299a803b3","city":"中卫","region":"宁夏","district":"沙坡头区","category":"甜品 / 饮品","categoryDetail":"蛋糕面包","name":"初见甜品","address":"创业场南门","price":"人均45","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":176},{"id":"99cef9f12f9b84","city":"中卫","region":"宁夏","district":"沙坡头区","category":"烧烤 / 烤肉","categoryDetail":"烤鱼","name":"马有鱼囊坑烤全鱼","address":"中山南街","price":"人均80","note":"鱼平均个头大推荐孜然香辣烤鱼凉皮不要点一般","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":177},{"id":"ccd2f3a703bf9e","city":"中卫","region":"宁夏","district":"沙坡头区","category":"烧烤 / 烤肉","categoryDetail":"特色烤鱼锁边","name":"爱上鱼水族生活观","address":"正丰交叉口正西方向","note":"先杀先烤的，人多一点吃，要不吃不完","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":178},{"id":"4493b5d5f5ce7c","city":"中卫","region":"宁夏","district":"沙坡头区","category":"烧烤 / 烤肉","categoryDetail":"烤肉","name":"碳和牛烤肉","address":"紫云新都南门","price":"人均80","tips":"不清真，有回族的朋友需要注意","note":"里面有个虾饼很好吃，还可以点饮料","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":179},{"id":"48670706d8e5db","city":"中卫","region":"宁夏","district":"中宁县","category":"汤锅 / 炖菜","categoryDetail":"焖锅","name":"品海棠","address":"政府后面，搜店名就可以","price":"人均60","tips":"不清真","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":180},{"id":"98c44f51b9c1d9","city":"固原","region":"宁夏","district":"西吉县","category":"其他美食","categoryDetail":"生汆（cuan）面","name":"米师汆面总店","address":"固原市西吉县吉强镇政府(近西涵路)","price":"大小碗 14-16左右","tips":"丸子是生汆的牛肉丸子，面是手工扯的长面，才正宗","note":"我爱生汆面！！！；竟然能看到我家，有这样的生命力，大家干什么都会幸福的","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":189},{"id":"2c2eef35d473c5","city":"固原","region":"宁夏","district":"隆德县","category":"其他美食","categoryDetail":"暖锅","name":"龍德暖锅","address":"隆德县博物馆正对面，龙城世家B区地门口","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":190},{"id":"5aea8ec56b1e59","city":"固原","region":"宁夏","district":"原州区","category":"烧烤 / 烤肉","categoryDetail":"烧烤","name":"虎娃烧烤","address":"下东海","price":"很平价， 六七十两个人吃的饱饱的","tips":"得自己收拾桌子，自己取餐， 下午六点之后开门","note":"牛肉和羊肉都是烤熟称斤，所以肉串特别大颗，超级顶饱，味道就是咸辣；量大实惠，而且味道确实很好，清真哦（PS：人比较多，老板的服务态度可能没想象的好，各位见谅）；肉都是按斤称，一般一个人吃半斤，一斤60元，大概按这个量点。非常实惠，爱肉星人吃很过瘾，牙不好咀嚼不好的不太适合会嚼不动。凉菜一盘10块钱自己夹。师专巷开了一家名字一样但是是假的，还得下东海财神楼这家。","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":191},{"id":"56a4d18adce03f","city":"固原","region":"宁夏","district":"原州区","category":"其他美食","categoryDetail":"暖锅","name":"隆德风味暖锅城","address":"晨光家园西区西门","price":"人均70左右","note":"主要是暖锅，还可以点其他凉菜（尖椒皮蛋和凉拌海笋非常解腻！），人多建议直接点大锅，女生2-3人点小锅再考虑其他","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":192},{"id":"353fe74415824b","city":"固原","region":"宁夏","district":"原州区","category":"火锅 / 串串","categoryDetail":"沾汁麻辣烫","name":"李记麻辣烫","address":"军分区道道","price":"人均20（吃很撑了）","tips":"沾汁更好吃 早晨一般不开门的 也可以尝试烩麻食","note":"每次回家必吃","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":194},{"id":"102dfce76cda42","city":"固原","region":"宁夏","district":"彭阳县","category":"面食 / 米粉","categoryDetail":"大盘鸡","name":"马良东大盘鸡","address":"商城背后","price":"80-150（小份四人足够）","tips":"超好吃的大盘鸡！去彭阳包要吃的啊姐妹们！","note":"土豆超好吃，可以搞碎拌面吃，香破脑袋了","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":195},{"id":"715ac02097cf23","city":"固原","region":"宁夏","district":"原州区","category":"火锅 / 串串","categoryDetail":"凉皮、麻辣烫","name":"香香面皮店","address":"文化巷2号（商城后门道道）","price":"麻辣烫人均20（凉皮人均10元）","tips":"人多，位置比较难抢，有空位就先占","note":"强推面皮掺牛筋面、八宝粥；dy有团购券特别划算！！","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":196},{"id":"a4f3684f8946db","city":"固原","region":"宁夏","district":"隆德县","category":"米饭 / 简餐","categoryDetail":"生汆面","name":"三营老周食府","address":"固原市隆德县书香世家店","price":"15左右","tips":"可以点小碗，量真的很大","note":"回固原必吃，在银川吃到的都没有那个味道，固原面食相较便宜，量多，且好吃！！！最喜欢那个丸子辣","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":197},{"id":"f74c2cdb5880a0","city":"固原","region":"宁夏","district":"原州区","category":"其他美食","categoryDetail":"大盘鸡","name":"佬兔鸡.鲜钞兔肉.红土鸡.清真","address":"固原市原州区博物馆店","price":"50左右","tips":"量大","note":"朋友小聚很合适；评价（点外卖肉少）牙口不好的朋友注意了，土鸡肉就是很结实的那种","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":198},{"id":"28052e0dfb5366","city":"固原","region":"宁夏","district":"原州区","category":"其他美食","categoryDetail":"大盘鸡","name":"新疆村大盘鸡","address":"固原市原州区安康花苑A区东南门东北90米","price":"50左右","tips":"量大，多要蒜","note":"一定要点土鸡，早点去或者打电话预定，土鸡买的特别快，建议带个饭量大的朋友，两个人小份中份都够够的！","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":199},{"id":"0f15370194567d","city":"固原","region":"宁夏","district":"隆德县","category":"火锅 / 串串","categoryDetail":"麻辣烫","name":"缘味麻辣烫","address":"阳光小区门口","price":"20左右","tips":"量大，辣的更好吃","note":"沾汁麻辣烫和米线都很好吃","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":200},{"id":"0dad8a9384b7ca","city":"固原","region":"宁夏","district":"原州区","category":"其他美食","categoryDetail":"羊肉","name":"摆家羊肉馆","address":"固原市原州区农校对面小巷子（可以问一下路人都知道）","price":"70左右","tips":"清炖的最好吃","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":202},{"id":"6b6c062af04414","city":"固原","region":"宁夏","district":"原州区","category":"面食 / 米粉","categoryDetail":"羊肉泡馍","name":"老白师羊肉泡馍烩肉（泰合总店）","address":"原州区泰合嘉园A区11号营业楼三层","price":"30左右","tips":"生意好，早点去","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":203},{"id":"7b60406663c6fb","city":"固原","region":"宁夏","district":"原州区","category":"海鲜 / 河鲜","categoryDetail":"干锅","name":"尚品麻辣干锅","address":"原州区新时代购物中心四楼","price":"50左右","tips":"不用买喝的，有大麦茶，好喝！送的紫菜汤也好喝","note":"每次吃的基本都是干锅鸡翅虾，虾很酥脆，我有时候都不剥壳","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":204},{"id":"b95cfe715322fc","city":"固原","region":"宁夏","district":"原州区","category":"面食 / 米粉","categoryDetail":"米粉","name":"张记桂林米粉","address":"原州区二市场","price":"20左右","tips":"三鲜干拌，点外卖必点","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":205},{"id":"776f76d9a658d9","city":"固原","region":"宁夏","district":"原州区","category":"面食 / 米粉","categoryDetail":"早餐","name":"于儿小笼包","address":"西关南街31号","price":"18左右","tips":"小笼包真的特别好吃每次通宵完必须去吃个包子回家睡觉，一笼牛肉包子10个18块钱价钱偏高，但是皮很喧软，馅也算多。","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":206},{"id":"c5bc143657fffa","city":"固原","region":"宁夏","district":"原州区","category":"早餐 / 小吃","categoryDetail":"燕面揉揉","name":"福苑饭庄","address":"东关路42号","price":"14","tips":"本地婚宴都在这家办，也接待散客，可以单独点菜点面吃。燕面揉揉只有固原有，这家好吃,像凉皮一样算主食，很大一盘。","sourceSheet":"宁夏篇","sourceUrl":"https://docs.qq.com/sheet/DWHpHUXJwYXJOTWVE?tab=1xgocf","sourceRow":207}]